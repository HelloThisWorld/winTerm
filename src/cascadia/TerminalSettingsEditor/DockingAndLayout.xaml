<Page x:Class="Microsoft.Terminal.Settings.Editor.DockingAndLayout"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="using:Microsoft.Terminal.Settings.Editor"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
      mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="CommonResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <DataTemplate x:Key="EnumComboBoxTemplate"
                          x:DataType="local:EnumEntry">
                <TextBlock Text="{x:Bind EnumName, Mode=OneWay}" />
            </DataTemplate>
        </ResourceDictionary>
    </Page.Resources>

    <StackPanel Style="{StaticResource SettingsStackStyle}">
        <TextBlock x:Uid="Globals_PaneResizingHeader"
                   Style="{StaticResource TextBlockSubHeaderStyle}" />

        <local:SettingContainer x:Name="PaneResizeSnapping"
                                x:Uid="Globals_PaneResizeSnapping">
            <ToggleSwitch IsOn="{x:Bind ViewModel.PaneResizeSnapping, Mode=TwoWay}"
                          Style="{StaticResource ToggleSwitchInExpanderStyle}" />
        </local:SettingContainer>

        <local:SettingContainer x:Name="PaneResizeSnapPoints"
                                x:Uid="Globals_PaneResizeSnapPoints">
            <ComboBox AutomationProperties.AccessibilityView="Content"
                      ItemTemplate="{StaticResource EnumComboBoxTemplate}"
                      ItemsSource="{x:Bind ViewModel.PaneResizeSnapPointsList, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.CurrentPaneResizeSnapPoints, Mode=TwoWay}"
                      Style="{StaticResource ComboBoxSettingStyle}" />
        </local:SettingContainer>

        <local:SettingContainer x:Name="PaneResizeCustomRatios"
                                x:Uid="Globals_PaneResizeCustomRatios"
                                CurrentValue="{x:Bind ViewModel.PaneResizeCustomRatios, Mode=OneWay}"
                                Style="{StaticResource ExpanderSettingContainerStyle}">
            <TextBox IsSpellCheckEnabled="False"
                     PlaceholderText="0.25, 0.5, 0.75"
                     Style="{StaticResource TextBoxSettingStyle}"
                     Text="{x:Bind ViewModel.PaneResizeCustomRatios, Mode=TwoWay}" />
        </local:SettingContainer>

        <local:SettingContainer x:Name="PaneResizeShowIndicator"
                                x:Uid="Globals_PaneResizeShowIndicator">
            <ToggleSwitch IsOn="{x:Bind ViewModel.PaneResizeShowIndicator, Mode=TwoWay}"
                          Style="{StaticResource ToggleSwitchInExpanderStyle}" />
        </local:SettingContainer>

        <local:SettingContainer x:Name="PaneResizeAltDisablesSnapping"
                                x:Uid="Globals_PaneResizeAltDisablesSnapping">
            <ToggleSwitch IsOn="{x:Bind ViewModel.PaneResizeAltDisablesSnapping, Mode=TwoWay}"
                          Style="{StaticResource ToggleSwitchInExpanderStyle}" />
        </local:SettingContainer>

        <local:SettingContainer x:Name="PaneResizeSnapThreshold"
                                x:Uid="Globals_PaneResizeSnapThreshold"
                                Style="{StaticResource ExpanderSettingContainerStyle}">
            <muxc:NumberBox Maximum="32"
                            Minimum="1"
                            SmallChange="1"
                            SpinButtonPlacementMode="Inline"
                            Value="{x:Bind ViewModel.PaneResizeSnapThreshold, Mode=TwoWay}" />
        </local:SettingContainer>

        <Button x:Uid="Globals_PaneResizeReset"
                Click="{x:Bind ViewModel.ResetPaneResizeDefaults}"
                HorizontalAlignment="Left" />
    </StackPanel>
</Page>
