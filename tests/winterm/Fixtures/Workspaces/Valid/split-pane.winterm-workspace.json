{
  "schemaVersion": 1,
  "id": "workspace.fixture-split",
  "name": "Fixture Split",
  "description": "A split-pane fixture.",
  "createdAt": "2026-07-15T00:00:00Z",
  "updatedAt": "2026-07-15T00:00:00Z",
  "source": "user",
  "applicationVersion": "0.4.0-dev",
  "protocolVersion": 1,
  "activeWindowId": "window-split",
  "windows": [
    {
      "id": "window-split",
      "monitor": {
        "deviceId": "DISPLAY-A",
        "stableId": "fixture-monitor-a",
        "friendlyName": "Primary Monitor",
        "workArea": { "x": 0, "y": 0, "width": 2560, "height": 1440 },
        "dpiX": 144,
        "dpiY": 144
      },
      "bounds": { "x": 100, "y": 80, "width": 1600, "height": 1000 },
      "normalizedBounds": { "x": 0.04, "y": 0.06, "width": 0.63, "height": 0.69 },
      "windowState": "maximized",
      "activeTabId": "tab-split",
      "tabs": [
        {
          "id": "tab-split",
          "title": "Development",
          "customTitle": true,
          "activePaneId": "pane-left",
          "panes": [
            {
              "id": "pane-left",
              "profileId": "{fixture-powershell}",
              "profileNameFallback": "PowerShell",
              "shellType": "powershell",
              "workingDirectory": { "kind": "windows", "value": "D:\\Code", "source": "shellIntegration" },
              "startingDirectoryFallback": "D:\\Code"
            },
            {
              "id": "pane-right",
              "profileId": "{fixture-cmd}",
              "profileNameFallback": "Command Prompt",
              "shellType": "cmd",
              "workingDirectory": { "kind": "windows", "value": "D:\\Code", "source": "profile" },
              "startingDirectoryFallback": "D:\\Code"
            }
          ],
          "layout": {
            "type": "split",
            "orientation": "vertical",
            "ratio": 0.58,
            "first": { "type": "pane", "paneId": "pane-left" },
            "second": { "type": "pane", "paneId": "pane-right" }
          }
        }
      ]
    }
  ]
}
